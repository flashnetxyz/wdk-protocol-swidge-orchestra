{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noImplicitAny": false,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["index.js", "src/**/*.js", "types/**/*.d.ts"]
}
