{
  "name": "wdk-protocol-swidge-orchestra",
  "version": "0.2.0",
  "description": "WDK Swidge protocol for routing swaps and bridges through Flashnet Orchestra.",
  "keywords": [
    "wdk",
    "protocol",
    "swap",
    "bridge",
    "swidge",
    "orchestra",
    "spark",
    "bitcoin",
    "btc",
    "flashnet"
  ],
  "author": "Flashnet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flashnetxyz/orchestra-wdk.git"
  },
  "bugs": {
    "url": "https://github.com/flashnetxyz/orchestra-wdk/issues"
  },
  "homepage": "https://github.com/flashnetxyz/orchestra-wdk#readme",
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "sideEffects": false,
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "live:init": "node scripts/live-test-env.js init",
    "live:addresses": "node scripts/live-test-env.js addresses",
    "live:quote": "node scripts/live-test-env.js quote",
    "live:prepare": "node scripts/live-test-env.js prepare",
    "live:execute": "node scripts/live-test-env.js execute",
    "live:resume": "node scripts/live-test-env.js resume",
    "live:status": "node scripts/live-test-env.js status",
    "live:wait": "node scripts/live-test-env.js wait",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@tetherto/wdk-wallet": "1.0.0-beta.11",
    "bare-node-runtime": "^1.1.4"
  },
  "devDependencies": {
    "@tetherto/wdk": "1.0.0-beta.12",
    "@tetherto/wdk-wallet-btc": "1.0.0-beta.10",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.14",
    "@tetherto/wdk-wallet-spark": "1.0.0-beta.21",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "standard": "^17.1.2",
    "typescript": "^5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "index.js",
    "bare.js",
    "src/",
    "scripts/",
    "types/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
